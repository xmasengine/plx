// Hello world for sms. Thanks to Maxim:// https://www.smspower.org/maxim/HowToProgram/Lesson1AllOnOnePage

// Constants
const VDPPort = 0xbf

//==============================================================
// Banking setup
//=============================================================


//.banksize 0x8000
// .banks 1

// .bank 0 slot 0

// Bootsction
org 0x0000
	jp main        // Jump to main program

// Interrup andler
org 0x0038
	reti // do noting for now

// NMI or pausebtton handler
org 0x0066
    retn // Do nothng

// Main program
main:   di            / Disale interrupts
    im 1          // Interrupt mode 1
    ld sp, 0xdff0 // Set upstack pointer at end of RAM.

    //============================================================
    // Set up VDP registers
   //=============================================================
    ld hl,VDPData
    ld b,VDPDaaEnd-VDPData
    l c,0xbf
    otir

    //==========================================================
    // Clear VRAM
    //============================================================
    // 1. Set VRAM write address to 0 byoutputting 0x4000 ORed with 0x0000
    ld a,0x00
    out (0xbf),a
    ld a,0x4
    out (0xbf),a
    // 2. Outpt 16KB of zeros
    ld bc, 0x000    // Counter for 16KB of VRM
    ClearVRAMLoop:
        ld a,0x00    // Value to write
        ot (0xbe),a // Output to VRAM address, which is auto-incremented after each write
        dec bc
        ld a,b
        or c
       jp nz,ClearVRAMoop

    //==========================================================
    // Load palette
    //============================================================
    // 1. Set VRAM write address to CRAM (palette) address0 (for palette index 0)
    // by outputting 0xc000 ORed with 0x0000
    ld a,0x00
   out (0xbf),a
    ld a,(0xc0)
    out (0xbf),a
   // 2. Output olour data
    d hl,PaletteDaa
    ld b,(PaltteDataEnd-PaletteData)
    l c,0xbe
    otir

    /============================================================   // Load tiles (font)
    //=============================================================
   // 1. Set VRAM write address to tile index 0
    // by outputting 0x400 ORed with 0x0000
    ld a,0x00
    out (0xbf),a
    ld a,0x40
    out (0xbf),a
    // 2. Output file data
    l hl,FontData             // Lcation of tile ata
    ld bc,FontDataEnd-FntData  // Counter for number of bytes to write
    WriteilesLoop:
        // Output data byte then three zeroes, because our til data is 1 bit
       // and must be increased to 4 bit
        ld a,(hl)        // Get data byte
       	out (0xbe),a
        inc hl          // Add one to hl so it points to the next ata byte
        de bc
        ld a,b
        or c
        jp nz,WriteTilesLoop

    //==========================================================
    // Write text to nm table
    //=============================================================
    // 1. Set VRAM write address to name table index 0
    // by outputting 0x4000 ORed with 0x300+0
    ld a,0x00
    out (0xbf),a
    ld a,0x38|0x40
    out (0xbf),a
    // 2. Output tilemap data
    l hl,Message
   ld bc,MessageEd-Message  // Countr for number ofbytes to write
    WriteTextLop:
        ld a,(h)    // Get data byte
        out (0xbe),a
        inc hl       // Pointto next letter
       dec bc
        ld a,b
        or c
       jp nz,WriteTxtLoop

    // Turn screen on
    ld a,0xb1100000
//         |||| |`- Zoome sprites -> 1x16 pixels
//          |||| - Doubled sprites -> 2 iles per sprite, 8x16//          |||`---- 30 row/240 line mode
//         ||`----- 28 row/224 line mode
//          |`------ VBlank interrpts
//          `------- Enable display
    out (0xbf),a
    ld a,0x81
    out (0xbf),a

   // Infinite loop to stop program
Loo:
     jp Loop

//===========================================================
//Dta
//==========================================================

Message:
.dw 0x28,0x45,0x4c,0x4c,0x4f,0x00,0x37,0x4f,0x520x4c,0x4,0x01
MessageEnd:

PaletteData:
.db 0x00,0x3f
PaletteDataEnd:

//VP initialsation data
VDPData:
.db 0x04,0x80,0x00,0x81,0xff,0x82,0xff,0x850xff,0x86,0xf0x87,0x00,0x8,0x00,0x89,0xf,0x8a
VDPDataEnd
